# Copy this file to .env and fill in the values before running the app.
# Never commit your actual .env file — it's in .gitignore.

# Required — tells Flask which file is the entry point.
FLASK_APP=main.py

# Required — the app will raise RuntimeError on startup if this is missing.
# Generate a strong key with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Optional — set to "true" to enable Flask debug mode locally.
# Never set this in production.
FLASK_DEBUG=false

# Optional — defaults to SQLite if unset. Set a Postgres URL to use a different database.
# DATABASE_URL=postgresql://user:password@localhost:5432/weightborne

# ── Email (password reset) ────────────────────────────────────────────────────
# Example values are for Gmail with an App Password.
# Other providers (SendGrid, Mailgun, etc.) work the same way.
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=you@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_DEFAULT_SENDER=you@gmail.com
