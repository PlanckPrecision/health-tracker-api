# Copy this file to .env and fill in the values before running the app.
# Never commit your actual .env file — it's in .gitignore.

# Required — the app will raise RuntimeError on startup if this is missing.
# Generate a strong key with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Optional — set to "true" to enable Flask debug mode locally.
# Never set this in production.
FLASK_DEBUG=false
